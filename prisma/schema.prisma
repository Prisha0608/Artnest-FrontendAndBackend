generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

model Artwork {
  id        Int      @id @default(autoincrement())

  username  String
  title     String
  price     Float
  image     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cart {
  id        Int      @id @default(autoincrement())

  name      String
  price     Float
  img       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        Int      @id @default(autoincrement())

  firstName String
  lastName  String
  email     String
  phone     String
  message   String

  createdAt DateTime @default(now())
}

model Product {
  id       Int    @id @default(autoincrement())

  name     String
  price    Float
  img      String
  category String

  @@map("product")
}

model Subscription {
  id        Int      @id @default(autoincrement())

  userId    String
  email     String
  payment   String

  date      DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())

  username  String   @unique
  contact   String
  password  String
  role      String   @default("user")

  fullname  String?
  bio       String?
  social    String?

  createdAt DateTime @default(now())
}